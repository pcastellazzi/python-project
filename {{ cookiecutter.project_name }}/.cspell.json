{
    "version": "0.2",

    "allowCompoundWords": true,
    "enabledFileTypes": { "*": true },
    "language": "en",
    "useGitignore": true,
    "validateDirectives": true,

    "dictionaryDefinitions": [
        {
            "name": "personal",
            "path": "~/.cspell-personal.txt",
            "scope": "user",
            "addWords": true
        },
        {
            "name": "project",
            "path": ".cspell-project.txt",
            "scope": "workspace",
            "addWords": true
        }
    ],
    "languageSettings": [
        {
            "languageId": "*",
            "dictionaries": [
                "companies",
                "softwareTerms",
                "misc",
                "personal",
                "project"
            ]
        },
        { "languageId": "python", "dictionaries": ["python"] }
    ]
}
