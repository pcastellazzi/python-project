{
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.py[cod]": true,
        "htmlcov": true,
        ".coverage": true,
        ".pytest_cache": true,
    },

    "python.formatting.provider": "black",
    "python.linting.banditEnabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.mypyEnabled": false,
    "python.linting.pylintEnabled": true,

    "[python]": {
        "editor.formatOnSave": true,
    },
}
