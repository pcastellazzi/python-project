{
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.py[cod]": true,
        ".coverage": true,
        ".pytest_cache": true,
        ".venv": true,
        ".tox": true
    },

    "python.formatting.provider": "black",
    "python.linting.banditEnabled": true,
    "python.linting.flake8Enabled": false,,
    "python.linting.mypyEnabled": false,
    "python.linting.pylintEnabled": true,

    "[python]": {
        "editor.formatOnSave": true
    }
}
